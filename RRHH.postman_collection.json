{
  "info": {
    "name": "RRHH API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register employee",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Empleado Demo\",\n  \"email\": \"empleado.demo@empresa.com\",\n  \"password\": \"Password123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"empleado.demo@empresa.com\",\n  \"password\": \"Password123\"\n}"
            }
          }
        },
        {
          "name": "Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/auth/profile"
          }
        },
        {
          "name": "Update profile",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/profile",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Empleado Demo Actualizado\"\n}"
            }
          }
        },
        {
          "name": "Recover password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/recover",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"empleado.demo@empresa.com\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        { "name": "List", "request": { "method": "GET", "url": "{{baseUrl}}/api/categories" } },
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/categories",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Talento Humano\",\n  \"description\": \"Area de RRHH\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        { "name": "List", "request": { "method": "GET", "url": "{{baseUrl}}/api/products" } }
      ]
    },
    {
      "name": "Docs",
      "item": [
        { "name": "Swagger UI", "request": { "method": "GET", "url": "{{baseUrl}}/api-docs" } }
      ]
    }
  ]
}
